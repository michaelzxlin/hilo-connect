#!/usr/bin/env python3
"""hilo — connect ANY runtime to a Hilo workspace as a first-class agent.

The open integration layer: a thin, dependency-free CLI over the node's `/api/agent/*` API.
Any runtime that can shell out becomes a full teammate — send/check messages, claim/update
tasks — using an agent credential (a `hilo_agent_…` token an admin mints in
Admin → Agents). This is the "connected" agent class: your code, your maintenance, full
citizenship. Nothing here imports node internals — it speaks only the public HTTP API.

Auth resolution (first wins): env HILO_NODE_URL + HILO_AGENT_TOKEN, then
~/.hilo-connect/config.json (written by `hilo login`).

Usage:
  hilo login --node https://node.example --token hilo_agent_XXXX
  hilo whoami
  hilo message check <conversation_id> [--since <message_id>]
  hilo message send  <conversation_id> <text…>
  hilo task list   <conversation_id>
  hilo task claim  <task_id>
  hilo task update <task_id> <todo|in_progress|in_review|closed>   # a human marks 'done'
"""
import json
import os
import sys
import urllib.error
import urllib.parse
import urllib.request

CFG = os.path.expanduser("~/.hilo-connect/config.json")


def die(msg, code=1):
    sys.stderr.write("hilo: " + msg + "\n")
    sys.exit(code)


def creds():
    url = os.environ.get("HILO_NODE_URL")
    tok = os.environ.get("HILO_AGENT_TOKEN")
    if (not url or not tok) and os.path.exists(CFG):
        try:
            c = json.load(open(CFG))
            url = url or c.get("node_url")
            tok = tok or c.get("token")
        except (OSError, ValueError):
            pass
    return url, tok


def call(method, path, data=None, url=None, tok=None):
    if url is None or tok is None:
        url, tok = creds()
    if not url or not tok:
        die("not logged in — run `hilo login --node URL --token hilo_agent_…` "
            "(or set HILO_NODE_URL / HILO_AGENT_TOKEN)")
    body = urllib.parse.urlencode(data).encode() if data is not None else None
    req = urllib.request.Request(url.rstrip("/") + path, data=body, method=method)
    req.add_header("Authorization", "Bearer " + tok)
    if data is not None:
        req.add_header("Content-Type", "application/x-www-form-urlencoded")
    try:
        resp = urllib.request.urlopen(req, timeout=20)
        return json.loads(resp.read() or b"{}")
    except urllib.error.HTTPError as e:
        detail = ""
        try:
            detail = json.loads(e.read() or b"{}").get("error", "")
        except Exception:
            pass
        die("%s%s" % (e.code, (" — " + detail) if detail else ""))
    except urllib.error.URLError as e:
        die("cannot reach the node: %s" % e.reason)


def opt(argv, name, default=None):
    return argv[argv.index(name) + 1] if name in argv and argv.index(name) + 1 < len(argv) else default


def main(argv):
    if not argv or argv[0] in ("-h", "--help", "help"):
        print(__doc__)
        return 0
    cmd, rest = argv[0], argv[1:]

    if cmd == "login":
        node, tok = opt(rest, "--node"), opt(rest, "--token")
        if not node or not tok:
            die("usage: hilo login --node URL --token hilo_agent_…")
        who = call("GET", "/api/agent/whoami", url=node, tok=tok)   # validate before saving
        os.makedirs(os.path.dirname(CFG), mode=0o700, exist_ok=True)
        # create 0600 from the start (not create-then-chmod) so the agent token is never
        # world-readable, even briefly, under the default umask
        fd = os.open(CFG, os.O_CREAT | os.O_WRONLY | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "w") as f:
            json.dump({"node_url": node, "token": tok}, f)
        print("logged in as agent:", who.get("agent"))
        return 0

    if cmd == "whoami":
        print(call("GET", "/api/agent/whoami").get("agent", "?"))
        return 0

    if cmd == "message":
        sub = rest[0] if rest else ""
        if sub == "check" and len(rest) >= 2:
            since = opt(rest, "--since", "0")
            d = call("GET", "/api/agent/messages?" + urllib.parse.urlencode(
                {"conversation_id": rest[1], "since": since}))
            for m in d.get("messages", []):
                print("#%s  %s: %s" % (m.get("id"), m.get("author"), (m.get("body") or "").replace("\n", " ")))
            return 0
        if sub == "send" and len(rest) >= 3:
            call("POST", "/api/agent/reply", {"conversation_id": rest[1], "text": " ".join(rest[2:])})
            print("sent")
            return 0
        die("usage: hilo message check <conv> [--since N] | send <conv> <text…>")

    if cmd == "task":
        sub = rest[0] if rest else ""
        if sub == "list" and len(rest) >= 2:
            for t in call("GET", "/api/agent/tasks?" + urllib.parse.urlencode(
                    {"conversation_id": rest[1]})).get("tasks", []):
                print("#%s [%s] %s%s" % (t.get("seq"), t.get("status"), t.get("title"),
                                         ("  (owner %s)" % t["owner"]) if t.get("owner") else ""))
            return 0
        if sub == "claim" and len(rest) >= 2:
            call("POST", "/api/agent/task-claim", {"task_id": rest[1]})
            print("claimed")
            return 0
        if sub == "update" and len(rest) >= 3:
            r = call("POST", "/api/agent/task-update", {"task_id": rest[1], "status": rest[2]})
            print("→", r.get("status"))
            return 0
        die("usage: hilo task list <conv> | claim <id> | update <id> <status>")

    die("unknown command '%s' — run `hilo help`" % cmd)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
